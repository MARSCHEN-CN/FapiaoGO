{
  "template_id": "default_v1",
  "version": 1,
  "status": "DEPRECATED",
  "schema_id": "invoice_v1",
  "schema_version": 1,
  "fingerprint": {
    "structural": {
      "table_count_min": 0,
      "table_count_max": 100,
      "region_count_min": 1,
      "region_count_max": 1000,
      "region_types": [
        "text",
        "table",
        "image",
        "stamp"
      ]
    },
    "visual": {
      "simhash": "",
      "embedding": []
    }
  },
  "extraction_rules": [
    {
      "rule_id": "extract_type",
      "field_id": "type",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(增值税电子普通发票|增值税专用发票|增值税普通发票|全电发票|电子发票)",
        "group": 1
      },
      "post_process": "strip_whitespace"
    },
    {
      "rule_id": "extract_type_fallback",
      "field_id": "type",
      "locator_type": "keyword",
      "locator_config": {
        "keywords": [
          "电子发票",
          "普通发票",
          "专用发票"
        ],
        "offset_x": 60
      },
      "post_process": "strip_whitespace"
    },
    {
      "rule_id": "extract_fphm",
      "field_id": "fphm",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "发票号码[:：]?\\s*([0-9]{8,20})",
        "group": 1
      },
      "post_process": null
    },
    {
      "rule_id": "extract_fphm_fallback",
      "field_id": "fphm",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(?<!电话)(?<!银行)(?<!税)(?<!手机)(?<!传真)(?<!账号)号码[:：]?\\s*([0-9]{8,20})",
        "group": 1
      },
      "post_process": null
    },
    {
      "rule_id": "extract_kprq",
      "field_id": "kprq",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "开票日期[:：]?\\s*(\\d{4}[-/年]\\d{1,2}[-/月]\\d{1,2}[日号]?)",
        "group": 1
      },
      "post_process": "parse_date"
    },
    {
      "rule_id": "extract_kprq_fallback",
      "field_id": "kprq",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(\\d{4}年\\d{1,2}月\\d{1,2}日)",
        "group": 1
      },
      "post_process": "parse_date"
    },
    {
      "rule_id": "extract_amountHj_keyword",
      "field_id": "amountHj",
      "locator_type": "keyword",
      "locator_config": {
        "keywords": [
          "（小写）",
          "(小写)",
          "小写金额",
          "价税合计",
          "合计金额",
          "总额"
        ],
        "offset_x": 100
      },
      "post_process": "clean_amount"
    },
    {
      "rule_id": "extract_amountHj_yen",
      "field_id": "amountHj",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "[¥￥]\\s*([\\d,]+\\u002e\\d{2})",
        "group": 1
      },
      "post_process": "clean_amount"
    },
    {
      "rule_id": "extract_gmfmc",
      "field_id": "gmfmc",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(?:购买方|购方)(?:名称)?[:：]?\\s*([\\u4e00-\\u9fa5A-Za-z0-9()（）\\-&/.]{4,40}(?:有限公司|有限责任公司|股份有限公司|集团|厂|店|中心|事务所|工作室|合伙|合作社))",
        "group": 1
      },
      "post_process": "strip_whitespace"
    },
    {
      "rule_id": "extract_xsfmc",
      "field_id": "xsfmc",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(?:销售方|销方)(?:名称)?[:：]?\\s*([\\u4e00-\\u9fa5A-Za-z0-9()（）\\-&/.]{4,40}(?:有限公司|有限责任公司|股份有限公司|集团|厂|店|中心|事务所|工作室|合伙|合作社))",
        "group": 1
      },
      "post_process": "strip_whitespace"
    },
    {
      "rule_id": "extract_gmfsh",
      "field_id": "gmfsh",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(?:购买方|购方).*?(?:纳税人识别号|统一社会信用代码|税号)[:：]?\\s*([A-Z0-9]{15,20})",
        "group": 1
      },
      "post_process": "extract_digits"
    },
    {
      "rule_id": "extract_xsfsh",
      "field_id": "xsfsh",
      "locator_type": "regex",
      "locator_config": {
        "pattern": "(?:销售方|销方).*?(?:纳税人识别号|统一社会信用代码|税号)[:：]?\\s*([A-Z0-9]{15,20})",
        "group": 1
      },
      "post_process": "extract_digits"
    }
  ],
  "validation_rules": []
}
