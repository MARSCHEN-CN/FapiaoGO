{
  "schema_id": "invoice_v1",
  "version": 1,
  "name": "增值税发票通用 Schema",
  "fields": [
    {"id": "type", "type": "string", "required": true, "validators": []},
    {"id": "fphm", "type": "string", "required": true, "validators": [
      {"type": "regex", "pattern": "^\\d{8,20}$", "message": "发票号码必须为8-20位数字"}
    ]},
    {"id": "kprq", "type": "date", "required": true, "validators": []},
    {"id": "gmfmc", "type": "string", "required": false, "validators": []},
    {"id": "gmfsh", "type": "string", "required": false, "validators": [
      {"type": "regex", "pattern": "^[A-Za-z0-9]{15,20}$", "message": "税号必须为15-20位字母数字"}
    ]},
    {"id": "xsfmc", "type": "string", "required": false, "validators": []},
    {"id": "xsfsh", "type": "string", "required": false, "validators": [
      {"type": "regex", "pattern": "^[A-Za-z0-9]{15,20}$", "message": "税号必须为15-20位字母数字"}
    ]},
    {"id": "amountJe", "type": "currency", "required": false, "validators": []},
    {"id": "amountSe", "type": "currency", "required": false, "validators": []},
    {"id": "amountHj", "type": "currency", "required": false, "validators": [
      {"type": "range", "min": 0, "max": 999999999.99, "message": "金额必须在0-999,999,999.99之间"}
    ]},
    {"id": "amountHjDx", "type": "string", "required": false, "validators": []},
    {"id": "xmmc", "type": "string", "required": false, "validators": []},
    {"id": "note", "type": "string", "required": false, "validators": []},
    {"id": "skr", "type": "string", "required": false, "validators": []},
    {"id": "fhr", "type": "string", "required": false, "validators": []},
    {"id": "kpr", "type": "string", "required": false, "validators": []}
  ]
}
